#!/bin/bash

echo "🔍 Running pre-commit validation..."

# Validate JSON content
if [ -f "scripts/validate-content.js" ]; then
    echo "Validating JSON files..."
    if ! CI=1 node scripts/validate-content.js; then
        echo "❌ Pre-commit validation failed. Please fix the issues above."
        exit 1
    fi
fi

echo "Checking formatting (Prettier)..."
if ! npm -w @glass-code-academy/api run format:check; then
    echo "❌ Prettier check failed in apps/api. Please run: npm -w @glass-code-academy/api run format"
    exit 1
fi
if ! npm -w @glass-code-academy/web run format:check; then
    echo "❌ Prettier check failed in apps/web. Please run: npm -w @glass-code-academy/web run format"
    exit 1
fi
if [ -f "glass-stats-starter/package.json" ]; then
    if ! npm -C glass-stats-starter run format:check; then
        echo "❌ Prettier check failed in glass-stats-starter. Please run: npm -C glass-stats-starter run format"
        exit 1
    fi
fi

echo "Running lint..."
if ! npm -w @glass-code-academy/api run lint; then
    echo "❌ ESLint failed in apps/api."
    exit 1
fi
if ! npm -w @glass-code-academy/web run lint; then
    echo "❌ ESLint failed in apps/web."
    exit 1
fi
if [ -f "glass-stats-starter/package.json" ]; then
    if ! npm -C glass-stats-starter run lint; then
        echo "❌ ESLint failed in glass-stats-starter."
        exit 1
    fi
fi

echo "✅ Pre-commit validation passed"
exit 0
